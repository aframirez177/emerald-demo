/* emerald.co — webgl-hero.js
   Procedural faceted emerald in Three.js with MeshPhysicalMaterial
   transmission. Placeholder RoomEnvironment lighting — swap to
   /assets/hdri/studio-environment.hdr via RGBELoader when Álvaro
   drops the file (see CLAUDE.md §7a).

   Bailouts:
   - prefers-reduced-motion  → show gradient fallback, skip WebGL
   - no WebGL support        → show gradient fallback
   - viewport < 900px        → show gradient fallback (perf + stacking)
   - element not in DOM      → no-op
*/

import * as THREE from "three";
import { RoomEnvironment } from "https://esm.sh/three@0.160.1/examples/jsm/environments/RoomEnvironment.js";

const MIN_VIEWPORT = 900;
const GEM_COLOR = 0x0A4F3C;
const SURFACE_COLOR = 0xF8F6F1;

export function initHeroWebGL(selector = "[data-webgl-hero]") {
  const host = document.querySelector(selector);
  if (!host) return null;

  if (shouldBailout()) {
    host.dataset.webglState = "fallback";
    return null;
  }

  host.dataset.webglState = "active";

  const scene = new THREE.Scene();
  scene.background = null;

  const camera = new THREE.PerspectiveCamera(35, 1, 0.1, 100);
  camera.position.set(0, 0, 5);

  const renderer = new THREE.WebGLRenderer({
    antialias: true,
    alpha: true,
    powerPreference: "high-performance",
  });
  renderer.setPixelRatio(Math.min(2, window.devicePixelRatio));
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.1;
  renderer.outputColorSpace = THREE.SRGBColorSpace;
  host.appendChild(renderer.domElement);

  // Environment: RoomEnvironment = programmatic stand-in until HDRI arrives
  const pmrem = new THREE.PMREMGenerator(renderer);
  const envMap = pmrem.fromScene(new RoomEnvironment(renderer), 0.04).texture;
  scene.environment = envMap;

  // The gem — faceted procedural. Icosahedron sphere-like, scaled to feel
  // elongated like a cushion/emerald cut without claiming to be one.
  const geometry = new THREE.IcosahedronGeometry(1, 0);
  geometry.computeVertexNormals();

  const material = new THREE.MeshPhysicalMaterial({
    color: 0xffffff,
    roughness: 0.02,
    metalness: 0,
    transmission: 0.98,
    thickness: 0.7,
    ior: 1.57,
    attenuationColor: GEM_COLOR,
    attenuationDistance: 1.2,
    clearcoat: 1.0,
    clearcoatRoughness: 0.05,
    envMapIntensity: 1.1,
    side: THREE.DoubleSide,
  });

  const gem = new THREE.Mesh(geometry, material);
  gem.scale.set(1.05, 1.35, 1.05);
  scene.add(gem);

  // A backdrop glow — a large faint disc behind the gem so the transmission
  // has something luminous to refract.
  const backdrop = new THREE.Mesh(
    new THREE.CircleGeometry(6, 64),
    new THREE.MeshBasicMaterial({
      color: SURFACE_COLOR,
      transparent: true,
      opacity: 0.85,
    })
  );
  backdrop.position.z = -3;
  scene.add(backdrop);

  // A warm rim light — so the edges of the gem get a bronze highlight that
  // reads as Muzo-adjacent. Reinforced by the environment.
  const rim = new THREE.DirectionalLight(0xffddaa, 1.4);
  rim.position.set(3, 2, 2);
  scene.add(rim);

  const fill = new THREE.DirectionalLight(0xc8e6d8, 0.6);
  fill.position.set(-2, -1, 1);
  scene.add(fill);

  // Mouse parallax
  const pointer = { x: 0, y: 0, tx: 0, ty: 0 };
  const onPointerMove = (e) => {
    const r = host.getBoundingClientRect();
    pointer.tx = ((e.clientX - r.left) / r.width - 0.5) * 2;
    pointer.ty = ((e.clientY - r.top) / r.height - 0.5) * 2;
  };
  window.addEventListener("pointermove", onPointerMove, { passive: true });

  // Responsive sizing
  const resize = () => {
    const { clientWidth: w, clientHeight: h } = host;
    if (!w || !h) return;
    renderer.setSize(w, h, false);
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
  };
  const resizeObserver = new ResizeObserver(resize);
  resizeObserver.observe(host);
  resize();

  // Pause when offscreen to save battery
  let visible = true;
  const intersect = new IntersectionObserver(
    (entries) => entries.forEach((e) => { visible = e.isIntersecting; }),
    { threshold: 0.01 }
  );
  intersect.observe(host);

  // Animation loop
  const clock = new THREE.Clock();
  let rafId = null;

  const render = () => {
    rafId = requestAnimationFrame(render);
    if (!visible) return;

    const dt = clock.getDelta();

    // Slow autorotate on Y + tiny wobble on X
    gem.rotation.y += dt * 0.35;
    gem.rotation.x = Math.sin(clock.elapsedTime * 0.4) * 0.12;

    // Pointer parallax — ease toward target
    pointer.x += (pointer.tx - pointer.x) * 0.06;
    pointer.y += (pointer.ty - pointer.y) * 0.06;
    camera.position.x = pointer.x * 0.25;
    camera.position.y = -pointer.y * 0.2;
    camera.lookAt(0, 0, 0);

    renderer.render(scene, camera);
  };
  render();

  // Dispose helper (for SPA nav, not used right now but clean)
  return {
    dispose() {
      cancelAnimationFrame(rafId);
      window.removeEventListener("pointermove", onPointerMove);
      resizeObserver.disconnect();
      intersect.disconnect();
      geometry.dispose();
      material.dispose();
      backdrop.geometry.dispose();
      backdrop.material.dispose();
      pmrem.dispose();
      renderer.dispose();
      renderer.domElement.remove();
    },
  };
}

function shouldBailout() {
  if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return true;
  if (window.innerWidth < MIN_VIEWPORT) return true;
  try {
    const canvas = document.createElement("canvas");
    const gl = canvas.getContext("webgl2") || canvas.getContext("webgl");
    if (!gl) return true;
  } catch {
    return true;
  }
  return false;
}
